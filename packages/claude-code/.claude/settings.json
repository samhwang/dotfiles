{
  "permissions": {
    "defaultMode": "plan"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true
  },
  "tui": "fullscreen",
  "editorMode": "vim",
  "verbose": true,
  "preferredNotifChannel": "ghostty",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  }
}
